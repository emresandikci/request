{
  "name": "@emstack/request",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "author": "emresandikci",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/emresandikci/request/issues"
  },
  "homepage": "https://github.com/emresandikci/request#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emresandikci/request.git"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "node .husky/install.mjs",
    "commit": "SKIP_COMMIT_CHECK=true git-cz",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,md}\"",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@semantic-release/changelog": "catalog:",
    "@semantic-release/git": "catalog:",
    "@semantic-release/github": "catalog:",
    "@semantic-release/npm": "catalog:",
    "@semantic-release/release-notes-generator": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "commitizen": "catalog:",
    "conventional-changelog-conventionalcommits": "catalog:",
    "cz-conventional-changelog": "catalog:",
    "prettier": "catalog:",
    "semantic-release": "catalog:",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "lint-staged": "catalog:",
    "husky": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "typescript-eslint": "^8.46.4",
    "@eslint/js": "^9.39.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
